# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional — defaults are shown below
# POSTGRES_DB=notifications
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=db
# POSTGRES_PORT=5432

# Web App URL — set to the public HTTPS URL where the webapp is hosted.
# Required for the "Open Web App" button to appear in the bot menu.
# Example: WEBAPP_URL=https://your-domain.com
# WEBAPP_URL=

# Port on which the webapp is exposed locally (default: 3000)
# WEBAPP_PORT=3000
